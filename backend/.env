# Configuration de la base de données MongoDB
# Pour le développement local (MongoDB installé sur votre machine)
MONGODB_URI=mongodb://localhost:27017/madaevasion

# Pour la production avec MongoDB Atlas (remplacez avec votre URL)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/madaevasion?retryWrites=true&w=majority

# Port du serveur
PORT=5000

# Secret JWT (gardez cette clé secrète en production)
JWT_SECRET=madaevasion_secret_key_2026
